# ============================================================
# SofaScore (via RapidAPI) — Robotrend IA
# Copie para .env:   copy .env.example .env   (Windows)
#                    cp  .env.example .env    (Linux/macOS)
# ============================================================

# Chave obtida em https://rapidapi.com/fluis.lacasse/api/sofascore
RAPIDAPI_KEY=SUA_CHAVE_AQUI

# Host do endpoint na RapidAPI (não mudar a menos que o provider mude)
RAPIDAPI_HOST=sofascore.p.rapidapi.com

# Timeout HTTP em segundos
SOFASCORE_TIMEOUT=15

# Esporte default consultado
SOFASCORE_SPORT=football

{
  "name": "robotrend-ia",
  "version": "5.0.0",
  "description": "Robotrend IA v5 Commercial — Bet365 SaaS · backtest, anti-fake-pressure v2, score adaptativo, watchdog, beta fechado, painel de resultados, qualidade IA, cupons/convites",
  "main": "backend/server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node backend/server.js",
    "dev": "cross-env NODE_ENV=development nodemon backend/server.js",
    "start:win": "node backend/server.js",
    "worker": "cross-env NODE_ENV=production node backend/worker.js",
    "worker:dev": "cross-env NODE_ENV=development nodemon backend/worker.js",
    "metrics": "curl -s -H \"X-Metrics-Token: %METRICS_TOKEN%\" http://localhost:3010/api/metrics | node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))\"",
    "backtest:synthetic": "node -e \"const b=require('./backend/backtest');const r=b.runBacktest(b.buildSyntheticDataset(500),{minScore:80,stake:1});console.log(JSON.stringify({summary:r.summary,byMarket:r.byMarket},null,2));\"",
    "secrets:generate": "node scripts/generate-secrets.js",
    "backup:phase1": "node scripts/backup-phase1.js",
    "secrets:apply": "node scripts/apply-secrets-to-env.js",
    "docker:up": "docker compose -f deploy/docker-compose.yml --env-file .env up -d --build",
    "docker:down": "docker compose -f deploy/docker-compose.yml down",
    "docker:logs": "docker compose -f deploy/docker-compose.yml logs -f app",
    "pm2:start": "pm2 start deploy/ecosystem.config.js",
    "pm2:stop": "pm2 stop robotrend-ia",
    "smoke": "node scripts/smoke-test.js",
    "tailwind:build": "tailwindcss -i ./frontend/input.css -o ./frontend/output.css --minify",
    "tailwind:watch": "tailwindcss -i ./frontend/input.css -o ./frontend/output.css --watch",
    "build":          "npm run tailwind:build",
    "postinstall":    "npm run tailwind:build",
    "ws:probe": "node scripts/ws-probe.js",
    "test:source": "node scripts/test-signal-source.js",
    "test:consensus": "node scripts/test-consensus.js",
    "test:apifootball": "node scripts/test-apifootball.js",
    "test:all": "node scripts/test-signal-source.js && node scripts/test-consensus.js && node scripts/test-apifootball.js",
    "load:sockets": "node scripts/load-test-sockets.js",
    "validate:realtime": "node scripts/validate-realtime.js",
    "validate:worker": "node scripts/worker-check.js",
    "audit:security": "node scripts/security-audit.js",
    "ops:checkall": "node scripts/worker-check.js && node scripts/security-audit.js && node scripts/test-apifootball.js",
    "stop": "node -e \"const n=require('net'); const c=n.connect(3010,'127.0.0.1',()=>{console.log('porta 3010 ativa - use Ctrl+C no terminal do servidor para parar.'); c.end();}); c.on('error',()=>console.log('porta 3010 livre.'));\""
  },
  "keywords": [
    "robotrend",
    "ia",
    "saas",
    "apostas",
    "escanteios",
    "btts",
    "telegram",
    "trading-esportivo",
    "live",
    "pwa",
    "stripe",
    "mercadopago"
  ],
  "author": "Robotrend IA",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "optionalDependencies": {
    "bullmq": "^5.21.0",
    "ioredis": "^5.4.1",
    "mercadopago": "^2.13.0",
    "stripe": "^17.3.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.1.7",
    "postcss": "^8.5.15",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.4.19"
  }
}

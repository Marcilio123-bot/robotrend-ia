# ============================================================
# ROBOTREND IA v5.0.0 — ENVIRONMENT (desenvolvimento)
# Copie para .env:  copy .env.example .env
# Produção: use .env.production + npm run secrets:generate
# ============================================================

PORT=3010
NODE_ENV=development
# URL base do app (links, callbacks). Fallback: http://localhost:PORT
BASE_URL=http://localhost:3010
PUBLIC_URL=http://localhost:3010

# CORS / WebSocket (dev: vazio = permissivo local)
ALLOWED_ORIGINS=http://localhost:3010

# Produção: npm run secrets:generate (JWT/SESSION = hex 128 chars, mín. 32)
JWT_SECRET=troque_em_dev_apenas_nao_use_em_producao_32chars_min
SESSION_SECRET=dev_session_secret_troque_em_producao_32chars_min_ok
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

BOOTSTRAP_ADMIN_EMAIL=admin@robotrend.local
BOOTSTRAP_ADMIN_PASSWORD=admin123

PLAN_FREE_DAILY_SIGNALS=3
PLAN_VIP_DAILY_SIGNALS=30
PLAN_PREMIUM_DAILY_SIGNALS=999
PLAN_VIP_PRICE_BRL=49.90
PLAN_PREMIUM_PRICE_BRL=199.99
PLAN_PREMIUM_FULL_PRICE_BRL=499.99

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Lista ordenada de providers (failover automático em 403 / breaker open).
# Default: thesportsdb (livre, sem chave) → sofascore → apisports.
#   - thesportsdb: gratuito, chave pública "3", endpoint /livescore.php
#   - sofascore:   API interna não-oficial (sujeita a 403/Cloudflare)
#   - apisports:   API-Football pago (precisa de API_FOOTBALL_KEY)
FOOTBALL_PROVIDER_PRIORITY=thesportsdb,sofascore,apisports
# Compat: se definido, sobrepõe o topo da prioridade.
# FOOTBALL_PROVIDER=thesportsdb

# Polling do live (ms). Default: 15000 com sofascore, 300000 com apisports.
# Override aqui se quiser forçar outro valor.
# FOOTBALL_POLL_INTERVAL_MS=15000

# Clock LOCAL — roda independente da API (mesmo em fallback/safe-mode).
# A cada FOOTBALL_FALLBACK_CLOCK_MS o poller emite `tick` com matches
# simulados (minute progride, pressureIndex faz drift). Garante que o
# painel nunca congele em 0' ou 120'.
# FOOTBALL_FALLBACK_CLOCK_MS=10000

# Lista (CSV) de tokens que descartam ligas do feed live.
# FOOTBALL_EXCLUDE_LEAGUES=Reserve,Women,U23,U21,U20,U19,U17,U16,Amateur,Kreisliga,2e Klasse,Bezirksliga,Youth

# Tuning Sofascore (todos opcionais)
# SOFASCORE_TIMEOUT_MS=12000
# SOFASCORE_RETRY_MAX=2
# SOFASCORE_TTL_LIVE_MS=15000
# SOFASCORE_TTL_STATS_MS=20000
# SOFASCORE_CB_THRESHOLD=5
# SOFASCORE_CB_COOLDOWN_MS=60000

# API-Football (fallback opt-in — só usado se FOOTBALL_PROVIDER=apisports)
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
ODDS_API_KEY=

DATABASE_URL=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=robotrend

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_VIP=
STRIPE_PRICE_PREMIUM=

MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

PIX_KEY=
PIX_MERCHANT_NAME=Robotrend IA
PIX_MERCHANT_CITY=Sao Paulo

# Token opcional p/ Prometheus scrape em /api/metrics (header X-Metrics-Token)
METRICS_TOKEN=

SIGNAL_MIN_SCORE=80
LIVE_SCAN_INTERVAL_MS=15000
DEMO_MODE=false
# Só aceita jogos REAIS confirmados pela API (default: true em prod/staging).
# Em dev, deixe false para usar scanner demo, true para forçar API real.
STRICT_REAL_ONLY=false
# Idade máxima (ms) do último update da API por match para emitir sinal.
SIGNAL_API_FRESH_MS=90000

# Multi-API Consensus Engine (ativo quando STRICT_REAL_ONLY=true)
CONSENSUS_RETRIES=3
CONSENSUS_RETRY_DELAY_MS=500
CONSENSUS_TS_TOLERANCE_MS=60000
CONSENSUS_FETCH_TIMEOUT_MS=10000
ANTI_FAKE_PRESSURE=true
ML_AUTOTUNE=true

FRESHNESS_PAST_HOURS=3
FRESHNESS_FUTURE_HOURS=24
WATCHDOG_INTERVAL_MS=30000
WATCHDOG_HEAP_MB=350
WATCHDOG_RSS_MB=500
WATCHDOG_P95_MS=1500
WATCHDOG_SELF_EXIT=true
